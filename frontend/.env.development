# ================================================
# FRONTEND — DEVELOPMENT (shared team config)
# Use this for normal local development shared by the team.
# Override only machine-specific values in frontend/.env.local
# All browser-exposed values must use NEXT_PUBLIC_
# ================================================

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=https://localhost:3000
NEXT_PUBLIC_WS_URL=https://localhost:3002
NEXT_PUBLIC_W3ID_LOGIN_URL=https://localhost:3002/api/v1/auth/w3id
NEXT_PUBLIC_IBM_LOGO_URL=https://upload.wikimedia.org/wikipedia/commons/5/51/IBM_logo.svg
NEXT_PUBLIC_DEFAULT_THEME=dark