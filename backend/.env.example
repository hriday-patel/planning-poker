# ================================================
# BACKEND ENVIRONMENT VARIABLES — TEMPLATE
# Copy to backend/.env.development for shared defaults
# or backend/.env.local for machine-specific overrides.
# ================================================

# Application
NODE_ENV=development
PORT=3002
API_BASE_URL=https://localhost:3002
FRONTEND_URL=https://localhost:3000

# CORS
CORS_ORIGIN=https://localhost:3000,https://localhost:3001
CORS_CREDENTIALS=true

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=planning_poker_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# IBM W3ID OAuth
W3ID_CLIENT_ID=your_w3id_client_id
W3ID_CLIENT_SECRET=your_w3id_client_secret
W3ID_AUTHORIZATION_URL=https://w3id.sso.ibm.com/auth/sps/oauth/oauth20/authorize
W3ID_TOKEN_URL=https://w3id.sso.ibm.com/auth/sps/oauth/oauth20/token
W3ID_USERINFO_URL=https://w3id.sso.ibm.com/auth/sps/oauth/oauth20/userinfo
W3ID_CALLBACK_URL=https://localhost:3002/api/v1/auth/w3id/callback

# IBM Blue Pages
BLUE_PAGES_URL=https://bluepages.ibm.com/BpHttpApisv3/slaphapi

# Invite Links
INVITE_TOKEN_TTL_SECONDS=604800

# JWT Authentication
JWT_SECRET=dev_access_secret_change_me
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=250

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Feature Flags
ENABLE_JIRA_INTEGRATION=false
ENABLE_LINEAR_INTEGRATION=false