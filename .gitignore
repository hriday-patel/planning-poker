# ================================================
# DEPENDENCIES
# ================================================
node_modules/
*/node_modules/

# Lock files — DO NOT ignore these
# package-lock.json and yarn.lock must be committed
# for reproducible installs across the team

# ================================================
# ENVIRONMENT VARIABLES
# ================================================

# These are IGNORED (never commit)
.env
.env.local
.env*.local

# These are COMMITTED (safe — no real secrets)
# .env.development   ← team shared dev config
# .env.production    ← placeholder values only
# .env.example       ← template for new developers

# ================================================
# DATABASE
# ================================================
*.db
*.sqlite
*.sqlite3
dump.rdb

# ================================================
# UPLOADS & TEMP FILES
# ================================================
uploads/
temp/
tmp/
*.tmp

# ================================================
# BUILD OUTPUTS
# ================================================
dist/
build/
.next/
out/
coverage/
.nyc_output/

# ================================================
# LOGS
# ================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ================================================
# IDE & OS
# ================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db